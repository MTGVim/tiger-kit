{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tigerkit.execute-support-matrix/v1",
  "title": "TigerKit execute support matrix v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "pluginVersion", "generatedAt", "environments"],
  "properties": {
    "schemaVersion": {"const": "tigerkit.execute-support-matrix/v1"},
    "pluginVersion": {"type": "string", "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:[-+][0-9A-Za-z.-]+)?$"},
    "generatedAt": {"type": "string"},
    "environments": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/environment"}}
  },
  "$defs": {
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["environmentKey", "status"],
      "properties": {
        "environmentKey": {"type": "string", "pattern": "^[a-z0-9._-]+/[a-z0-9._-]+/[a-z0-9._-]+/[a-z0-9._-]+$"},
        "status": {"enum": ["public", "preview", "unsupported"]},
        "boundaryArchitecture": {"enum": ["hook_gate", "read_only_view", "isolated_patch_apply", "privileged_helper", "trusted_tool_identity"]},
        "boundaryComponents": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
        "reason": {"type": "string", "minLength": 1}
      },
      "allOf": [
        {"if": {"properties": {"status": {"enum": ["public", "preview"]}}}, "then": {"required": ["boundaryArchitecture", "boundaryComponents"]}},
        {"if": {"properties": {"status": {"const": "unsupported"}}}, "then": {"required": ["reason"], "not": {"anyOf": [{"required": ["boundaryArchitecture"]}, {"required": ["boundaryComponents"]}]}}}
      ]
    }
  }
}
