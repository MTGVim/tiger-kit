{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:tigerkit:execution-receipt:v1",
  "title": "TigerKit execution receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "executionId", "specId", "result", "boundaryEnforcement", "reasonCodes", "reasonDetails", "observed", "postflightVerifiers", "safeToRetry", "cleanupRequired", "recommendedActions"],
  "properties": {
    "schemaVersion": {"const": "tigerkit.execution-receipt/v1"},
    "executionId": {"type": "string", "minLength": 1},
    "specId": {"type": "string", "minLength": 1},
    "executor": {"enum": ["fast", "reasoning"]},
    "result": {"enum": ["completed", "escalated", "failed", "rejected"]},
    "boundaryEnforcement": {"enum": ["hard", "detection_only"]},
    "reasonCodes": {"type": "array", "items": {"$ref": "#/$defs/reasonCode"}, "uniqueItems": true},
    "reasonDetails": {"type": "array", "items": {"$ref": "#/$defs/reasonDetail"}},
    "claimed": {"type": "object", "additionalProperties": false, "required": ["outcome", "changedPaths", "verifierResults", "reasonCodes", "reasonDetails"], "properties": {"outcome": {"enum": ["completed", "escalated", "failed"]}, "changedPaths": {"$ref": "#/$defs/pathList"}, "verifierResults": {"type": "array", "items": {"$ref": "#/$defs/claimedVerifier"}}, "reasonCodes": {"type": "array", "items": {"$ref": "#/$defs/reasonCode"}}, "reasonDetails": {"type": "array", "items": {"$ref": "#/$defs/reasonDetail"}}}},
    "baseline": {"type": "object", "additionalProperties": false, "required": ["headSha", "dirtyPaths"], "properties": {"headSha": {"type": "string", "minLength": 1}, "dirtyPaths": {"$ref": "#/$defs/pathList"}}},
    "observed": {"type": "object", "additionalProperties": false, "required": ["changedPaths", "scopeViolations", "baselineDirtyPathsModified", "claimedObservedMismatch"], "properties": {"changedPaths": {"$ref": "#/$defs/pathList"}, "scopeViolations": {"type": "array", "items": {"$ref": "#/$defs/scopeViolation"}}, "baselineDirtyPathsModified": {"$ref": "#/$defs/pathList"}, "claimedObservedMismatch": {"type": "boolean"}}},
    "postflightVerifiers": {"type": "array", "items": {"$ref": "#/$defs/postflightVerifier"}},
    "safeToRetry": {"type": "boolean"},
    "cleanupRequired": {"type": "boolean"},
    "recommendedActions": {"type": "array", "items": {"$ref": "#/$defs/recommendedAction"}, "uniqueItems": true}
  },
  "allOf": [
    {"if": {"properties": {"result": {"enum": ["completed", "failed", "escalated"]}}, "required": ["result"]}, "then": {"required": ["baseline", "executor"], "properties": {"boundaryEnforcement": {"const": "hard"}}}},
    {"if": {"properties": {"result": {"enum": ["completed", "failed"]}}, "required": ["result"]}, "then": {"properties": {"observed": {"properties": {"scopeViolations": {"maxItems": 0}, "baselineDirtyPathsModified": {"maxItems": 0}, "claimedObservedMismatch": {"const": false}}}}}},
    {"if": {"properties": {"result": {"const": "rejected"}}, "required": ["result"]}, "then": {"not": {"anyOf": [{"required": ["baseline"]}, {"required": ["claimed"]}, {"required": ["executor"]}]}, "properties": {"boundaryEnforcement": {"const": "detection_only"}, "observed": {"properties": {"changedPaths": {"maxItems": 0}, "scopeViolations": {"maxItems": 0}, "baselineDirtyPathsModified": {"maxItems": 0}, "claimedObservedMismatch": {"const": false}}}, "postflightVerifiers": {"maxItems": 0}}}},
    {"if": {"properties": {"observed": {"properties": {"claimedObservedMismatch": {"const": true}}, "required": ["claimedObservedMismatch"]}}, "required": ["observed"]}, "then": {"properties": {"result": {"const": "escalated"}, "reasonCodes": {"contains": {"const": "claimed_observed_mismatch"}}}}},
    {"if": {"properties": {"observed": {"properties": {"baselineDirtyPathsModified": {"minItems": 1}}, "required": ["baselineDirtyPathsModified"]}}, "required": ["observed"]}, "then": {"properties": {"result": {"const": "escalated"}, "reasonCodes": {"contains": {"const": "baseline_dirty_path_modified"}}}}}
  ],
  "$defs": {
    "pathList": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "scopeViolation": {"type": "object", "additionalProperties": false, "required": ["path", "operation", "violation"], "properties": {"path": {"type": "string"}, "operation": {"enum": ["create", "modify", "delete"]}, "violation": {"enum": ["excluded", "outside_modify_scope", "undeclared_create", "undeclared_delete"]}}, "allOf": [{"if": {"properties": {"violation": {"const": "outside_modify_scope"}}, "required": ["violation"]}, "then": {"properties": {"operation": {"const": "modify"}}}}, {"if": {"properties": {"violation": {"const": "undeclared_create"}}, "required": ["violation"]}, "then": {"properties": {"operation": {"const": "create"}}}}, {"if": {"properties": {"violation": {"const": "undeclared_delete"}}, "required": ["violation"]}, "then": {"properties": {"operation": {"const": "delete"}}}}]},
    "reasonCode": {"enum": ["spec_not_found", "ambiguous_spec_reference", "unsupported_loop_spec_schema", "invalid_loop_spec", "blocked_loop_spec", "missing_executor_recommendation", "missing_executor_mapping", "repository_identity_mismatch", "worktree_identity_mismatch", "scope_key_mismatch", "stale_base_revision", "stale_fingerprint", "scope_resolution_drift", "invalid_scope_pattern", "unsupported_path_encoding", "case_collision", "unsupported_scope_entry_type", "invalid_create_delete_state", "dirty_scoped_path", "dirty_excluded_path", "unresolved_merge_conflict", "required_verifier_unavailable", "hard_enforcement_unavailable", "plan_deviation_required", "scope_expansion_required", "executor_capability_mismatch", "concurrent_drift", "scope_violation", "excluded_path_modified", "unapproved_path_created", "unapproved_path_deleted", "claimed_observed_mismatch", "baseline_dirty_path_modified", "dispatcher_boundary_violation", "head_changed_concurrently", "executor_error", "required_tool_unavailable", "verifier_failed", "verifier_error", "verifier_timed_out", "budget_exhausted", "success_condition_not_met", "receipt_persistence_failed", "transient_runtime_failure"]},
    "reasonDetail": {"type": "object", "additionalProperties": false, "required": ["code"], "properties": {"code": {"$ref": "#/$defs/reasonCode"}, "message": {"type": "string", "minLength": 1}, "verifierId": {"type": "string", "minLength": 1}}},
    "verifierReasonCode": {"enum": ["process_start_error", "environment_error", "harness_error", "timeout_exceeded", "not_attempted_due_to_escalation", "not_attempted_due_to_prior_failure", "not_attempted_due_to_budget", "not_attempted_due_to_unavailable_tool", "not_attempted_due_to_invalid_final_state"]},
    "claimedVerifier": {"type": "object", "additionalProperties": false, "required": ["id", "status", "exitCode"], "properties": {"id": {"type": "string"}, "status": {"enum": ["passed", "failed", "error", "timed_out", "not_run"]}, "exitCode": {"type": ["integer", "null"]}, "reasonCode": {"$ref": "#/$defs/verifierReasonCode"}, "message": {"type": "string", "minLength": 1}}},
    "postflightVerifier": {"type": "object", "additionalProperties": false, "required": ["id", "command", "status", "exitCode"], "properties": {"id": {"type": "string"}, "command": {"type": "string"}, "status": {"enum": ["passed", "failed", "error", "timed_out", "not_run"]}, "exitCode": {"type": ["integer", "null"]}, "reasonCode": {"$ref": "#/$defs/verifierReasonCode"}, "message": {"type": "string", "minLength": 1}}},
    "recommendedAction": {"enum": ["regenerate_loop_spec", "resolve_blockers", "revise_loop_spec", "review_partial_changes", "cleanup_partial_changes", "resolve_concurrent_drift", "restore_required_tool", "retry_execute", "inspect_scope_violation", "inspect_enforcement_failure", "inspect_loop_spec", "resolve_worktree_state", "resolve_merge_conflict", "refresh_capability_proof", "report_runtime_failure"]}
  }
}
