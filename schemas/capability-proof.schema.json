{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tigerkit.capability-proof/execute-write-boundary-v1",
  "title": "TigerKit execute write-boundary capability proof v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "pluginVersion", "environmentKey", "runtimeBinding", "supportMatrixDigest", "componentDigests", "tests"],
  "properties": {
    "schemaVersion": {"const": "tigerkit.capability-proof/execute-write-boundary-v1"},
    "pluginVersion": {"type": "string", "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:[-+][0-9A-Za-z.-]+)?$"},
    "environmentKey": {"type": "string", "minLength": 1},
    "runtimeBinding": {"type": "object", "additionalProperties": false, "required": ["platform", "permissionMode", "isolationMode"], "properties": {"platform": {"enum": ["linux", "darwin", "windows"]}, "permissionMode": {"enum": ["default", "acceptEdits", "auto", "dontAsk", "plan", "bypassPermissions"]}, "isolationMode": {"enum": ["none", "worktree"]}}},
    "supportMatrixDigest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "componentDigests": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["path", "sha256"], "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}}}},
    "tests": {"type": "array", "prefixItems": [
      {"$ref": "#/$defs/cap01"}, {"$ref": "#/$defs/cap02"}, {"$ref": "#/$defs/cap03"}, {"$ref": "#/$defs/cap04"}, {"$ref": "#/$defs/cap05"},
      {"$ref": "#/$defs/cap06"}, {"$ref": "#/$defs/cap07"}, {"$ref": "#/$defs/cap08"}, {"$ref": "#/$defs/cap09"}, {"$ref": "#/$defs/cap10"}
    ], "minItems": 10, "maxItems": 10}
  },
  "$defs": {
    "test": {"type": "object", "additionalProperties": false, "required": ["id", "status"], "properties": {"id": {"type": "string"}, "status": {"const": "passed"}, "message": {"type": "string"}}},
    "cap01": {"allOf": [{"$ref": "#/$defs/test"}, {"properties": {"id": {"const": "CAP-01"}}}]},
    "cap02": {"allOf": [{"$ref": "#/$defs/test"}, {"properties": {"id": {"const": "CAP-02"}}}]},
    "cap03": {"allOf": [{"$ref": "#/$defs/test"}, {"properties": {"id": {"const": "CAP-03"}}}]},
    "cap04": {"allOf": [{"$ref": "#/$defs/test"}, {"properties": {"id": {"const": "CAP-04"}}}]},
    "cap05": {"allOf": [{"$ref": "#/$defs/test"}, {"properties": {"id": {"const": "CAP-05"}}}]},
    "cap06": {"allOf": [{"$ref": "#/$defs/test"}, {"properties": {"id": {"const": "CAP-06"}}}]},
    "cap07": {"allOf": [{"$ref": "#/$defs/test"}, {"properties": {"id": {"const": "CAP-07"}}}]},
    "cap08": {"allOf": [{"$ref": "#/$defs/test"}, {"properties": {"id": {"const": "CAP-08"}}}]},
    "cap09": {"allOf": [{"$ref": "#/$defs/test"}, {"properties": {"id": {"const": "CAP-09"}}}]},
    "cap10": {"allOf": [{"$ref": "#/$defs/test"}, {"properties": {"id": {"const": "CAP-10"}}}]}
  }
}
