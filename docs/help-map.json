{
  "schemaVersion": "tigerkit.help-map/v1",
  "source": "commands/*.md frontmatter",
  "commands": [
    {
      "command": "/tk:arch-review",
      "path": "commands/arch-review.md",
      "description": "구조 마찰을 검토합니다.",
      "argument_hint": "\"<scope|goal|area>\" [--target <path|area>] [--print-checklist]",
      "flow": []
    },
    {
      "command": "/tk:browser-verify",
      "path": "commands/browser-verify.md",
      "description": "browser-verify QA를 실행합니다.",
      "argument_hint": "\"<screen or verify task>\" [--mode <env-diff|figma-diff|behavior-verify>] [--print-profile-template]",
      "flow": []
    },
    {
      "command": "/tk:gap",
      "path": "commands/gap.md",
      "description": "SoT gap을 분석합니다.",
      "argument_hint": "[SoT refs or pasted source] [--target <path|area>] [--print-report]",
      "flow": [
        "/tk:route",
        "/tk:next"
      ]
    },
    {
      "command": "/tk:grill",
      "path": "commands/grill.md",
      "description": "계획 허점을 압박 검증합니다.",
      "argument_hint": "\"<plan|RFC|idea>\" [--target <path|area>] [--print-checklist]",
      "flow": []
    },
    {
      "command": "/tk:grooming",
      "path": "commands/grooming.md",
      "description": "guidance 정비안을 점검합니다.",
      "argument_hint": "\"[scope]\" [--scope <user|repo|all>] [--apply=true]",
      "flow": []
    },
    {
      "command": "/tk:handoff",
      "path": "commands/handoff.md",
      "description": "세션 handoff를 만듭니다.",
      "argument_hint": "\"[goal or audience]\" [--output <path>] [--print-only]",
      "flow": [
        "/tk:handon",
        "/tk:next"
      ]
    },
    {
      "command": "/tk:handon",
      "path": "commands/handon.md",
      "description": "current-first handoff를 다시 읽습니다.",
      "argument_hint": "[\"<focus or question>\"] [--path-only]",
      "flow": [
        "/tk:next",
        "/tk:route"
      ]
    },
    {
      "command": "/tk:help",
      "path": "commands/help.md",
      "description": "entrypoint navigation을 정리합니다.",
      "argument_hint": "\"[question or situation]\" [--print-map]",
      "flow": [
        "/tk:gap",
        "/tk:route",
        "/tk:grill",
        "/tk:to-prd",
        "/tk:to-issues",
        "/tk:handoff",
        "/tk:browser-verify",
        "/tk:next"
      ]
    },
    {
      "command": "/tk:learn",
      "path": "commands/learn.md",
      "description": "reusable skill을 만듭니다.",
      "argument_hint": "\"<source or request>\" [--name <slug>] [--apply=false|true] [--from-reflect <candidate_id>] [--dry-run]",
      "flow": []
    },
    {
      "command": "/tk:merge-conflict",
      "path": "commands/merge-conflict.md",
      "description": "merge/rebase conflict를 정리합니다.",
      "argument_hint": "[--target <file|path>] [--print-plan]",
      "flow": []
    },
    {
      "command": "/tk:next",
      "path": "commands/next.md",
      "description": "다음 command 1개를 고릅니다.",
      "argument_hint": "\"[task or resume request]\" [--print-reasoning]",
      "flow": [
        "/tk:gap",
        "/tk:route",
        "/tk:to-prd",
        "/tk:to-issues",
        "/tk:quiz",
        "/tk:handoff"
      ]
    },
    {
      "command": "/tk:prototype",
      "path": "commands/prototype.md",
      "description": "throwaway prototype으로 검증합니다.",
      "argument_hint": "\"<idea>\" [--ui|--logic] [--target <path|area>] [--print-plan]",
      "flow": []
    },
    {
      "command": "/tk:quiz",
      "path": "commands/quiz.md",
      "description": "머지 전 이해도 게이트를 엽니다.",
      "argument_hint": "\"[focus]\" [--path <area>] [--print-report]",
      "flow": [
        "/tk:route",
        "/tk:next",
        "/tk:handoff"
      ]
    },
    {
      "command": "/tk:reflect",
      "path": "commands/reflect.md",
      "description": "learning을 분류합니다.",
      "argument_hint": "\"[candidate_id|scope]\" [--apply=false|true] [--target <repo-local|repo-shared|user-global|skill|hook|command|agent|discard>] [--desc \"<freeform description>\"] [--dry-run]",
      "flow": []
    },
    {
      "command": "/tk:route",
      "path": "commands/route.md",
      "description": "구현 route를 고릅니다.",
      "argument_hint": "\"<task>\" [--context <note>] [--target <path|area>] [--print-checklist]",
      "flow": [
        "/tk:next",
        "/tk:quiz",
        "/tk:handoff"
      ]
    },
    {
      "command": "/tk:to-issues",
      "path": "commands/to-issues.md",
      "description": "vertical-slice issue draft를 만듭니다.",
      "argument_hint": "\"<plan or prd>\" [--output <path>] [--print-only]",
      "flow": [
        "/tk:route",
        "/tk:next",
        "/tk:handoff"
      ]
    },
    {
      "command": "/tk:to-prd",
      "path": "commands/to-prd.md",
      "description": "draft PRD를 작성합니다.",
      "argument_hint": "\"<goal or requirement>\" [--output <path>] [--print-only]",
      "flow": [
        "/tk:to-issues",
        "/tk:route",
        "/tk:next"
      ]
    },
    {
      "command": "/tk:wayfinder",
      "path": "commands/wayfinder.md",
      "description": "shared map을 정리합니다.",
      "argument_hint": "\"[goal or map update]\" [--print-only]",
      "flow": [
        "/tk:route",
        "/tk:next",
        "/tk:handoff"
      ]
    }
  ]
}
